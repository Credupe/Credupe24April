{
  "name": "credupe-api",
  "version": "1.0.0",
  "description": "Credupe backend on Cloudflare Workers + D1 (Hono + Drizzle).",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply credupe --local",
    "db:migrate:remote": "wrangler d1 migrations apply credupe --remote",
    "db:studio": "drizzle-kit studio",
    "seed:local": "wrangler d1 execute credupe --local --file=./scripts/seed.sql",
    "seed:remote": "wrangler d1 execute credupe --remote --file=./scripts/seed.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.12",
    "drizzle-orm": "^0.36.4",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "@types/bcryptjs": "^2.4.6",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}
